# Node runtime
NODE_ENV=production
PORT=3000

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Optional override if you use non-default RTDB instance
# FIREBASE_DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com

# Security / networking
# Comma-separated list. Required in production for browser clients.
CORS_ORIGINS=https://contacts.example.com
# Set true when running behind reverse proxy (Nginx/ALB/Cloudflare)
TRUST_PROXY=true

# Rate limit controls
RATE_LIMIT_MAX_BUCKETS=10000

# Bulk import job recovery
IMPORT_JOB_STALE_MINUTES=30
